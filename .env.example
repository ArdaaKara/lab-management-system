# =============================================================
# .env.example — Computer Lab Management System (MySQL)
# Kopyala: cp .env.example .env
# .env dosyasını ASLA Git'e ekleme (.gitignore'a ekle)
# =============================================================

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_DATABASE=clms_db
MYSQL_USER=clms_user
# ZORUNLU — openssl rand -base64 32
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# ── JWT ───────────────────────────────────────────────────────
# ZORUNLU — minimum 256-bit: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_BASE64_SECRET_MINIMUM_256_BIT

JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Spring ────────────────────────────────────────────────────
SPRING_PROFILE=prod

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO

# ── Docker image registry ─────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_OWNER=your-github-username
APP_VERSION=latest

# ── Host port binding ─────────────────────────────────────────
HOST_HTTP_PORT=80
HOST_HTTPS_PORT=443
